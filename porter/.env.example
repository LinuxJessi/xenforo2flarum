# Copy this file to .env (in your nitro-porter checkout, next to compose.yml)
# and fill in real values. .env is gitignored — never put real secrets here.

# Source database — holds your imported XenForo data.
XENFORO_DB_ROOT_PASSWORD=change-me-root
XENFORO_DB_NAME=xenforo
XENFORO_DB_USER=xenforo
XENFORO_DB_PASSWORD=change-me-xenforo

# Host UID/GID for the FrankenPHP container. Match `id -u` / `id -g` so files
# the container writes back into the checkout stay owned by you.
UID=1000
GID=1000
